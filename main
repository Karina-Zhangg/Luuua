local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local EggsFolder = workspace:WaitForChild("EggHuntMinigame"):WaitForChild("Eggs")
local NestPosition = Vector3.new(695.14, 50.30, 7968.96)

-- Configuration
getgenv().AutoFarm = true
getgenv().MaxEggsBeforeDeposit = 10 
local currentEggCount = 0
local lastCollectionTime = tick() 

-- Improved Position & Physics Utility
local function SafeTeleport(root, pos)
    if not root then return end
    
    -- 1. Reset Physics to prevent 'velocity stalls'
    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    
    -- 2. Apply CFrame with 3-stud height offset
    root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
end

local GetPosition = function(v)
    if not v then return nil end
    return (v:IsA("Model") and v:GetPivot().Position or v:IsA("BasePart") and v.Position)
end

-- Main Loop
task.spawn(function()
    while getgenv().AutoFarm do
        task.wait(0.5) 
        
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if not root or not hum then continue end

        -- STUCK CHECK: If no egg collected in 1.5s, nudge the character
        if tick() - lastCollectionTime > 1.5 then
            -- Walk backward relative to current facing direction
            hum:Move(Vector3.new(0, 0, 1), true) 
        else
            hum:Move(Vector3.new(0, 0, 0), true) 
        end

        -- Deposit Logic
        if currentEggCount >= getgenv().MaxEggsBeforeDeposit then
            print("🧺 Basket Full! Teleporting to Nest...")
            SafeTeleport(root, NestPosition)
            task.wait(0.8) -- Give the server time to process deposit
            currentEggCount = 0
            lastCollectionTime = tick() 
            continue
        end

        -- Targeting Logic
        local targetEgg = nil
        local shortestDistance = math.huge
        
        for _, egg in ipairs(EggsFolder:GetChildren()) do
            local pos = GetPosition(egg)
            if pos then
                local dist = (root.Position - pos).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    targetEgg = egg
                end
            end
        end

        -- Collection Logic
        if targetEgg then
            local eggPos = GetPosition(targetEgg)
            SafeTeleport(root, eggPos)
            
            -- Fire Touch Interest
            local touchPart = targetEgg:IsA("Model") and (targetEgg.PrimaryPart or targetEgg:FindFirstChildWhichIsA("BasePart")) or targetEgg
            if touchPart then
                firetouchinterest(root, touchPart, 0)
                task.wait(0.05)
                firetouchinterest(root, touchPart, 1)
            end
            
            currentEggCount = currentEggCount + 1
            lastCollectionTime = tick() -- Reset the 'stuck' timer
        end
    end
end)
